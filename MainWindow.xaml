<Window x:Class="RaceLabsOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:widgets="clr-namespace:RaceLabsOverlay.Widgets"
        Title="RaceLabs Overlay"
        Height="600"
        Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#0A0A0A">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                
                <TextBlock Text="🏎️ RaceLabs Overlay" 
                          FontSize="28" 
                          FontWeight="Bold"
                          Foreground="LimeGreen"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,20"
                          Width="760"
                          TextAlignment="Center"/>
                
                <!-- Row 1: Speed + RPM + Lap Timer -->
                <widgets:SpeedometerWidget x:Name="SpeedWidget" Margin="10"/>
                <widgets:RPMGaugeWidget x:Name="RPMWidget" Margin="10"/>
                <widgets:LapTimerWidget x:Name="LapWidget" Margin="10"/>
                
                <!-- Row 2: Fuel + Inputs + Tire Temps -->
                <widgets:FuelWidget x:Name="FuelWidget" Margin="10"/>
                <widgets:InputsWidget x:Name="InputsWidget" Margin="10"/>
                <widgets:TireTempsWidget x:Name="TireWidget" Margin="10"/>
                
                <!-- Row 3: Standings + Sector Times + Relative -->
                <widgets:StandingsWidget x:Name="StandingsWidget" Margin="10"/>
                <widgets:SectorTimesWidget x:Name="SectorWidget" Margin="10"/>
                <widgets:RelativeWidget x:Name="RelativeWidget" Margin="10"/>
                
                <!-- Row 4: Track Map + Minimap -->
                <widgets:TrackMapWidget x:Name="TrackMapWidget" Margin="10"/>
                <widgets:MinimapWidget x:Name="MinimapWidget" Margin="10"/>
                
                <!-- Row 5: Delta + Ghost + Telemetry Graph -->
                <widgets:DeltaBarWidget x:Name="DeltaWidget" Margin="10"/>
                <widgets:GhostComparatorWidget x:Name="GhostWidget" Margin="10"/>
                <widgets:TelemetryGraphWidget x:Name="GraphWidget" Margin="10"/>
                
                <TextBlock x:Name="StatusText"
                          Text="Running..." 
                          FontSize="12" 
                          Foreground="#888888"
                          HorizontalAlignment="Center"
                          Margin="0,20,0,0"
                          Width="760"
                          TextAlignment="Center"/>
            </WrapPanel>
        </ScrollViewer>
    </Grid>
</Window>
