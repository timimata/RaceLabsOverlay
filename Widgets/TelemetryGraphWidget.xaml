&lt;UserControl x:Class="RaceLabsOverlay.Widgets.TelemetryGraphWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Width="500" Height="300"&gt;
    
    &lt;Border Style="{StaticResource WidgetBaseStyle}"&gt;
        &lt;Grid Margin="10"&gt;
            &lt;Grid.RowDefinitions&gt;
                &lt;RowDefinition Height="Auto"/&gt;
                &lt;RowDefinition Height="*"/&gt;
                &lt;RowDefinition Height="*"/&gt;
                &lt;RowDefinition Height="*"/&gt;
            &lt;/Grid.RowDefinitions&gt;
            
            &lt;!-- Header com valores atuais --&gt;
            &lt;StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5"&gt;
                &lt;TextBlock Text="TELEMETRY" FontSize="10" Foreground="#888888" Margin="0,0,10,0"/&gt;
                &lt;TextBlock x:Name="CurrentSpeedText" Text="0 km/h" FontSize="11" Foreground="LimeGreen" FontWeight="Bold"/&gt;
                &lt;TextBlock Text=" • " Foreground="#555"/&gt;
                &lt;TextBlock x:Name="CurrentRpmText" Text="0 RPM" FontSize="11" Foreground="Orange" FontWeight="Bold"/&gt;
                &lt;TextBlock Text=" • " Foreground="#555"/&gt;
                &lt;TextBlock x:Name="CurrentGearText" Text="Gear N" FontSize="11" Foreground="White" FontWeight="Bold"/&gt;
            &lt;/StackPanel&gt;
            
            &lt;!-- Speed Chart --&gt;
            &lt;Grid Grid.Row="1"&gt;
                &lt;Grid.ColumnDefinitions&gt;
                    &lt;ColumnDefinition Width="25"/&gt;
                    &lt;ColumnDefinition Width="*"/&gt;
                &lt;/Grid.ColumnDefinitions&gt;
                
                &lt;TextBlock Grid.Column="0" Text="SPD" FontSize="8" Foreground="#888888" 
                          VerticalAlignment="Center" HorizontalAlignment="Center"
                          RenderTransform="{StaticResource Rotate90}"/&gt;
                
                &lt;lvc:CartesianChart x:Name="SpeedChart" Grid.Column="1"
                                   Height="60"
                                   Background="Transparent"
                                   DrawMarginFrame="False"
                                   TooltipPosition="Hidden"/&gt;
            &lt;/Grid&gt;
            
            &lt;!-- RPM Chart --&gt;
            &lt;Grid Grid.Row="2"&gt;
                &lt;Grid.ColumnDefinitions&gt;
                    &lt;ColumnDefinition Width="25"/&gt;
                    &lt;ColumnDefinition Width="*"/&gt;
                &lt;/Grid.ColumnDefinitions&gt;
                
                &lt;TextBlock Grid.Column="0" Text="RPM" FontSize="8" Foreground="#888888" 
                          VerticalAlignment="Center" HorizontalAlignment="Center"
                          RenderTransform="{StaticResource Rotate90}"/&gt;
                
                &lt;lvc:CartesianChart x:Name="RpmChart" Grid.Column="1"
                                   Height="60"
                                   Background="Transparent"
                                   DrawMarginFrame="False"
                                   TooltipPosition="Hidden"/&gt;
            &lt;/Grid&gt;
            
            &lt;!-- Inputs Chart --&gt;
            &lt;Grid Grid.Row="3"&gt;
                &lt;Grid.ColumnDefinitions&gt;
                    &lt;ColumnDefinition Width="25"/&gt;
                    &lt;ColumnDefinition Width="*"/&gt;
                &lt;/Grid.ColumnDefinitions&gt;
                
                &lt;TextBlock Grid.Column="0" Text="IN" FontSize="8" Foreground="#888888" 
                          VerticalAlignment="Center" HorizontalAlignment="Center"
                          RenderTransform="{StaticResource Rotate90}"/&gt;
                
                &lt;lvc:CartesianChart x:Name="InputsChart" Grid.Column="1"
                                   Height="60"
                                   Background="Transparent"
                                   DrawMarginFrame="False"
                                   TooltipPosition="Hidden"/&gt;
            &lt;/Grid&gt;
        &lt;/Grid&gt;
    &lt;/Border&gt;
    
    &lt;UserControl.Resources&gt;
        &lt;RotateTransform x:Key="Rotate90" Angle="-90"/&gt;
    &lt;/UserControl.Resources&gt;
&lt;/UserControl>
