<UserControl x:Class="RaceLabsOverlay.Widgets.GhostComparatorWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="400" Height="100">
  <Border Style="{StaticResource WidgetBaseStyle}">
    <Grid Margin="8">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="30"/>
      </Grid.RowDefinitions>

      <!-- Delta and Status -->
      <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
        <TextBlock x:Name="DeltaText" Text="+0.00" FontSize="24" FontWeight="Bold" Foreground="White"/>
        <TextBlock x:Name="StatusText" Text="AHEAD" FontSize="14" Foreground="LimeGreen"
                   Margin="10,5,0,0" VerticalAlignment="Bottom"/>
      </StackPanel>

      <!-- Ghost Speed -->
      <TextBlock x:Name="GhostSpeedText" Grid.Row="1" Text="Ghost: 0 km/h"
                 FontSize="11" Foreground="#888888" HorizontalAlignment="Center"/>

      <!-- Comparison Bar -->
      <Grid x:Name="BarContainer" Grid.Row="2" Height="16" Margin="0,6,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="4"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Ahead bar (green, fills from centre to left) -->
        <Rectangle x:Name="AheadBar" Grid.Column="0" Width="0" Height="12"
                   HorizontalAlignment="Right" Fill="LimeGreen"/>

        <!-- Centre divider -->
        <Rectangle Grid.Column="1" Fill="#555555"/>

        <!-- Behind bar (red, fills from centre to right) -->
        <Rectangle x:Name="BehindBar" Grid.Column="2" Width="0" Height="12"
                   HorizontalAlignment="Left" Fill="Red"/>

        <!-- Arrow indicator (overlaid on whole bar) -->
        <Canvas Grid.Column="0" Grid.ColumnSpan="3">
          <Polygon x:Name="ArrowIndicator" Points="0,-6 6,6 -6,6" Fill="White"
                   Canvas.Left="50" Canvas.Top="4">
            <Polygon.RenderTransform>
              <TranslateTransform/>
            </Polygon.RenderTransform>
          </Polygon>
        </Canvas>
      </Grid>

      <!-- Track mini-map -->
      <Grid Grid.Row="3">
        <Rectangle x:Name="TrackRepresentation" Fill="#333333" Height="4" VerticalAlignment="Center"/>
        <Canvas>
          <Ellipse x:Name="PlayerMarker" Width="10" Height="10" Fill="LimeGreen" Canvas.Top="10">
            <Ellipse.RenderTransform>
              <TranslateTransform/>
            </Ellipse.RenderTransform>
          </Ellipse>
          <Ellipse x:Name="GhostMarker" Width="10" Height="10" Fill="Orange" Canvas.Top="10">
            <Ellipse.RenderTransform>
              <TranslateTransform/>
            </Ellipse.RenderTransform>
          </Ellipse>
        </Canvas>
      </Grid>
    </Grid>
  </Border>
</UserControl>
