<UserControl x:Class="RaceLabsOverlay.Widgets.GhostComparatorWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="400" Height="100">
    
    <Border Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1" CornerRadius="8">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0" Text="GHOST COMPARATOR" 
                      FontSize="10" Foreground="#888888" 
                      HorizontalAlignment="Center"/>
            
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Rectangle x:Name="AheadBar" Grid.Column="0" Fill="LimeGreen" 
                          Height="20" HorizontalAlignment="Right" Width="0"/>
                
                <StackPanel Grid.Column="1" HorizontalAlignment="Center" Margin="10,0">
                    <TextBlock x:Name="DeltaText" Text="+0.00" 
                              FontSize="20" FontWeight="Bold" Foreground="White"/>
                    
                    <TextBlock x:Name="StatusText" Text="ON TRACK" 
                              FontSize="10" Foreground="#888888" HorizontalAlignment="Center"/>
                </StackPanel>
                
                <Rectangle x:Name="BehindBar" Grid.Column="2" Fill="Red" 
                          Height="20" HorizontalAlignment="Left" Width="0"/>
            </Grid>
            
            <TextBlock x:Name="GhostSpeedText" Grid.Row="2" 
                      Text="Ghost: — km/h" FontSize="10" Foreground="#888888"
                      HorizontalAlignment="Center"/>
        </Grid>
    </Border>
</UserControl>
