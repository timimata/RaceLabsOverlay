<UserControl x:Class="RaceLabsOverlay.Widgets.StandingsWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="180" Height="120">

    <Border Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1" CornerRadius="8">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="STANDINGS"
                      FontSize="10" Foreground="#888888"
                      HorizontalAlignment="Center" Margin="0,0,0,5"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="PositionBig" Text="2"
                              FontSize="48" FontWeight="ExtraBold" Foreground="White"
                              VerticalAlignment="Bottom"/>

                    <TextBlock x:Name="PositionSuffix" Text="nd"
                              FontSize="16" FontWeight="Bold" Foreground="#888888"
                              VerticalAlignment="Top" Margin="0,10,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="of " FontSize="12" Foreground="#888888"/>
                        <TextBlock x:Name="TotalCars" Text="24" FontSize="14" FontWeight="Bold" Foreground="White"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock Text="&#x25BC; " FontSize="10" Foreground="#FF6666"/>
                        <TextBlock x:Name="GapToLeader" Text="+2.456"
                                  FontSize="11" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBlock Text="&#x25B2; " FontSize="10" Foreground="#66FF66"/>
                        <TextBlock x:Name="GapToNext" Text="+0.234"
                                  FontSize="11" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                <TextBlock x:Name="CurrentLap" Text="Lap 12/50"
                          FontSize="11" Foreground="#CCCCCC"/>
                <TextBlock Text=" &#x2022; " Foreground="#555"/>
                <TextBlock x:Name="ClassPosition" Text="P2 in Class"
                          FontSize="10" Foreground="#888888"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
