&lt;UserControl x:Class="RaceLabsOverlay.Widgets.StandingsWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="180" Height="120"&gt;
    
    &lt;Border Style="{StaticResource WidgetBaseStyle}"&gt;
        &lt;Grid Margin="10"&gt;
            &lt;Grid.RowDefinitions&gt;
                &lt;RowDefinition Height="Auto"/&gt;
                &lt;RowDefinition Height="*"/&gt;
                &lt;RowDefinition Height="Auto"/&gt;
            &lt;/Grid.RowDefinitions&gt;
            
            &lt;TextBlock Grid.Row="0" Text="STANDINGS" 
                      FontSize="10" Foreground="#888888" 
                      HorizontalAlignment="Center" Margin="0,0,0,5"/&gt;
            
            &lt;Grid Grid.Row="1"&gt;
                &lt;Grid.ColumnDefinitions&gt;
                    &lt;ColumnDefinition Width="Auto"/&gt;
                    &lt;ColumnDefinition Width="*"/&gt;
                &lt;/Grid.ColumnDefinitions&gt;
                
                &lt;StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"&gt;
                    &lt;TextBlock x:Name="PositionBig" Text="2" 
                              FontSize="48" FontWeight="ExtraBold" Foreground="White"
                              VerticalAlignment="Bottom"/&gt;
                    
                    &lt;TextBlock x:Name="PositionSuffix" Text="nd" 
                              FontSize="16" FontWeight="Bold" Foreground="#888888"
                              VerticalAlignment="Top" Margin="0,10,0,0"/&gt;
                &lt;/StackPanel&gt;
                
                &lt;StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0"&gt;
                    &lt;StackPanel Orientation="Horizontal"&gt;
                        &lt;TextBlock Text="of " FontSize="12" Foreground="#888888"/&gt;
                        &lt;TextBlock x:Name="TotalCars" Text="24" FontSize="14" FontWeight="Bold" Foreground="White"/&gt;
                    &lt;/StackPanel&gt;
                    
                    &lt;StackPanel Orientation="Horizontal" Margin="0,5,0,0"&gt;
                        &lt;TextBlock Text="▼ " FontSize="10" Foreground="#FF6666"/&gt;
                        &lt;TextBlock x:Name="GapToLeader" Text="+2.456" 
                                  FontSize="11" FontWeight="Bold"/&gt;
                    &lt;/StackPanel&gt;
                    
                    &lt;StackPanel Orientation="Horizontal" Margin="0,2,0,0"&gt;
                        &lt;TextBlock Text="▲ " FontSize="10" Foreground="#66FF66"/&gt;
                        &lt;TextBlock x:Name="GapToNext" Text="+0.234" 
                                  FontSize="11" FontWeight="Bold"/&gt;
                    &lt;/StackPanel&gt;
                &lt;/StackPanel&gt;
            &lt;/Grid&gt;
            
            &lt;StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0"&gt;
                &lt;TextBlock x:Name="CurrentLap" Text="Lap 12/50" 
                          FontSize="11" Foreground="#CCCCCC"/&gt;
                &lt;TextBlock Text=" • " Foreground="#555"/&gt;
                &lt;TextBlock x:Name="ClassPosition" Text="P2 in Class" 
                          FontSize="10" Foreground="#888888"/&gt;
            &lt;/StackPanel&gt;
        </Grid>
    </Border>
</UserControl>
