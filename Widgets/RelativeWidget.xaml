<UserControl x:Class="RaceLabsOverlay.Widgets.RelativeWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="220" Height="180">

    <Border Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1" CornerRadius="8">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="RELATIVE"
                      FontSize="10" Foreground="#888888"
                      HorizontalAlignment="Center" Margin="0,0,0,8"/>

            <!-- Car ahead -->
            <Grid Grid.Row="1" Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="35"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="Position1Text" Grid.Column="0" Text="P1"
                          FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                <TextBlock x:Name="Car1Text" Grid.Column="1" Text="#24"
                          FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                <TextBlock x:Name="Gap1Text" Grid.Column="2" Text="+0.234"
                          FontSize="14" FontWeight="Bold" Foreground="#FF6666"
                          HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>

            <!-- Your car (highlight) -->
            <Grid Grid.Row="2" Margin="0,2">
                <Grid.Background>
                    <SolidColorBrush x:Name="Background2" Color="#228822" Opacity="0.2"/>
                </Grid.Background>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="35"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="Position2Text" Grid.Column="0" Text="P2"
                          FontSize="12" Foreground="#00FF00" VerticalAlignment="Center"/>
                <TextBlock x:Name="Car2Text" Grid.Column="1" Text="YOU"
                          FontSize="14" FontWeight="Bold" Foreground="#00FF00" VerticalAlignment="Center"/>
                <TextBlock x:Name="Gap2Text" Grid.Column="2" Text="---"
                          FontSize="14" FontWeight="Bold" Foreground="#00FF00"
                          HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>

            <!-- Car behind -->
            <Grid Grid.Row="3" Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="35"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="Position3Text" Grid.Column="0" Text="P3"
                          FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                <TextBlock x:Name="Car3Text" Grid.Column="1" Text="#07"
                          FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                <TextBlock x:Name="Gap3Text" Grid.Column="2" Text="-0.567"
                          FontSize="14" FontWeight="Bold" Foreground="#66FF66"
                          HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>

            <!-- Extra info -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                <TextBlock x:Name="CurrentPositionText" Text="P2" FontSize="12" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="TotalCarsText" Text="/ 24 cars" FontSize="10" Foreground="#888888" Margin="5,0,0,0"/>
                <TextBlock Text="&#x2022;" Foreground="#555" Margin="8,0"/>
                <TextBlock x:Name="LapsToLeaderText" Text="+2 laps" FontSize="10" Foreground="#FF6666"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
