&lt;UserControl x:Class="RaceLabsOverlay.Widgets.RelativeWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="220" Height="180"&gt;
    
    &lt;Border Style="{StaticResource WidgetBaseStyle}"&gt;
        &lt;Grid Margin="10"&gt;
            &lt;Grid.RowDefinitions&gt;
                &lt;RowDefinition Height="Auto"/&gt;
                &lt;RowDefinition Height="*"/&gt;
                &lt;RowDefinition Height="*"/&gt;
                &lt;RowDefinition Height="*"/&gt;
                &lt;RowDefinition Height="Auto"/&gt;
            &lt;/Grid.RowDefinitions&gt;
            
            &lt;TextBlock Grid.Row="0" Text="RELATIVE" 
                      FontSize="10" Foreground="#888888" 
                      HorizontalAlignment="Center" Margin="0,0,0,8"/&gt;
            
            &lt;!-- Car à frente --&gt;
            &lt;Grid Grid.Row="1" Margin="0,2"&gt;
                &lt;Grid.ColumnDefinitions&gt;
                    &lt;ColumnDefinition Width="35"/&gt;
                    &lt;ColumnDefinition Width="50"/&gt;
                    &lt;ColumnDefinition Width="*"/&gt;
                &lt;/Grid.ColumnDefinitions&gt;
                
                &lt;TextBlock x:Name="Position1Text" Grid.Column="0" Text="P1" 
                          FontSize="12" Foreground="#888888" VerticalAlignment="Center"/&gt;
                &lt;TextBlock x:Name="Car1Text" Grid.Column="1" Text="#24" 
                          FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/&gt;
                
                &lt;TextBlock x:Name="Gap1Text" Grid.Column="2" Text="+0.234" 
                          FontSize="14" FontWeight="Bold" Foreground="#FF6666" 
                          HorizontalAlignment="Right" VerticalAlignment="Center"/&gt;
            &lt;/Grid&gt;
            
            &lt;!-- Teu carro (highlight) --&gt;
            &lt;Grid Grid.Row="2" Margin="0,2"&gt;
                &lt;Grid.Background&gt;
                    &lt;SolidColorBrush x:Name="Background2" Color="#228822" Opacity="0.2"/&gt;
                &lt;/Grid.Background&gt;
                
                &lt;Grid.ColumnDefinitions&gt;
                    &lt;ColumnDefinition Width="35"/&gt;
                    &lt;ColumnDefinition Width="50"/&gt;
                    &lt;ColumnDefinition Width="*"/&gt;
                &lt;/Grid.ColumnDefinitions&gt;
                
                &lt;TextBlock x:Name="Position2Text" Grid.Column="0" Text="P2" 
                          FontSize="12" Forecolor="#00FF00" VerticalAlignment="Center"/&gt;
                
                &lt;TextBlock x:Name="Car2Text" Grid.Column="1" Text="YOU" 
                          FontSize="14" FontWeight="Bold" Foreground="#00FF00" VerticalAlignment="Center"/&gt;
                
                &lt;TextBlock x:Name="Gap2Text" Grid.Column="2" Text="——" 
                          FontSize="14" FontWeight="Bold" Foreground="#00FF00" 
                          HorizontalAlignment="Right" VerticalAlignment="Center"/&gt;
            &lt;/Grid&gt;
            
            &lt;!-- Car atrás --&gt;
            &lt;Grid Grid.Row="3" Margin="0,2"&gt;
                &lt;Grid.ColumnDefinitions&gt;
                    &lt;ColumnDefinition Width="35"/&gt;
                    &lt;ColumnDefinition Width="50"/&gt;
                    &lt;ColumnDefinition Width="*"/&gt;
                &lt;/Grid.ColumnDefinitions&gt;
                
                &lt;TextBlock x:Name="Position3Text" Grid.Column="0" Text="P3" 
                          FontSize="12" Foreground="#888888" VerticalAlignment="Center"/&gt;
                
                &lt;TextBlock x:Name="Car3Text" Grid.Column="1" Text="#07" 
                          FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/&gt;
                
                &lt;TextBlock x:Name="Gap3Text" Grid.Column="2" Text="-0.567" 
                          FontSize="14" FontWeight="Bold" Foreground="#66FF66" 
                          HorizontalAlignment="Right" VerticalAlignment="Center"/&gt;
            &lt;/Grid&gt;
            
            &lt;!-- Info extra --&gt;
            &lt;StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0"&gt;
                &lt;TextBlock x:Name="CurrentPositionText" Text="P2" FontSize="12" FontWeight="Bold" Foreground="White"/&gt;
                &lt;TextBlock x:Name="TotalCarsText" Text="/ 24 cars" FontSize="10" Foreground="#888888" Margin="5,0,0,0"/&gt;
                &lt;TextBlock Text="•" Foreground="#555" Margin="8,0"/&gt;
                &lt;TextBlock x:Name="LapsToLeaderText" Text="+2 laps" FontSize="10" Foreground="#FF6666"/&gt;
            &lt;/StackPanel&gt;
        &lt;/Grid&gt;
    &lt;/Border&gt;
&lt;/UserControl&gt;
