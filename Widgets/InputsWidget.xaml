<UserControl x:Class="RaceLabsOverlay.Widgets.InputsWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="150" Height="200">
    
    <Border Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1" CornerRadius="8">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0" Text="INPUTS" 
                      FontSize="10" Foreground="#888888" 
                      HorizontalAlignment="Center" Margin="0,0,0,5"/>
            
            <!-- Throttle -->
            <Grid Grid.Row="1" Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="25"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="T" 
                          Foreground="LimeGreen" FontSize="10" 
                          VerticalAlignment="Center"/>
                
                <Border Grid.Column="1" Background="#333333" Height="20" CornerRadius="2">
                    <Rectangle x:Name="ThrottleBar" 
                              Fill="LimeGreen" 
                              HorizontalAlignment="Left"
                              Width="0"/>
                </Border>
            </Grid>
            
            <!-- Brake -->
            <Grid Grid.Row="2" Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="25"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="B" 
                          Foreground="Red" FontSize="10" 
                          VerticalAlignment="Center"/>
                
                <Border Grid.Column="1" Background="#333333" Height="20" CornerRadius="2">
                    <Rectangle x:Name="BrakeBar" 
                              Fill="Red" 
                              HorizontalAlignment="Left"
                              Width="0"/>
                </Border>
            </Grid>
            
            <!-- Clutch -->
            <Grid Grid.Row="3" Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="25"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="C" 
                          Foreground="Orange" FontSize="10" 
                          VerticalAlignment="Center"/>
                
                <Border Grid.Column="1" Background="#333333" Height="20" CornerRadius="2">
                    <Rectangle x:Name="ClutchBar" 
                              Fill="Orange" 
                              HorizontalAlignment="Left"
                              Width="0"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
