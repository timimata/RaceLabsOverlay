&lt;UserControl x:Class="RaceLabsOverlay.Widgets.SectorTimesWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="200" Height="140"&gt;
    
    &lt;Border Style="{StaticResource WidgetBaseStyle}"&gt;
        &lt;Grid Margin="10"&gt;
            &lt;Grid.RowDefinitions&gt;
                &lt;RowDefinition Height="Auto"/&gt;
                &lt;RowDefinition Height="*"/&gt;
                &lt;RowDefinition Height="*"/&gt;
                &lt;RowDefinition Height="*"/&gt;
                &lt;RowDefinition Height="Auto"/&gt;
            &lt;/Grid.RowDefinitions&gt;
            
            &lt;TextBlock Grid.Row="0" Text="SECTORS" 
                      FontSize="10" Foreground="#888888" 
                      HorizontalAlignment="Center" Margin="0,0,0,5"/&gt;
            
            &lt;!-- Sector 1 --&gt;
            &lt;Grid Grid.Row="1"&gt;
                &lt;Grid.ColumnDefinitions&gt;
                    &lt;ColumnDefinition Width="25"/&gt;
                    &lt;ColumnDefinition Width="55"/&gt;
                    &lt;ColumnDefinition Width="50"/&gt;
                    &lt;ColumnDefinition Width="*"/&gt;
                &lt;/Grid.ColumnDefinitions&gt;
                
                &lt;TextBlock Grid.Column="0" Text="S1" FontSize="11" Foreground="#888888"/&gt;
                &lt;TextBlock x:Name="S1Time" Grid.Column="1" Text="32.456" 
                          FontSize="12" FontWeight="Bold" Foreground="White"/&gt;
                
                &lt;TextBlock x:Name="S1Delta" Grid.Column="2" Text="-0.234" 
                          FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/&gt;
                
                &lt;Border Grid.Column="3" Background="#333333" Height="4" CornerRadius="2" 
                       Margin="5,0,0,0" VerticalAlignment="Center"&gt;
                    &lt;Rectangle x:Name="S1Bar" Fill="LimeGreen" Width="40" 
                              HorizontalAlignment="Left" Height="4" RadiusX="2" RadiusY="2"/&gt;
                &lt;/Border&gt;
            &lt;/Grid&gt;
            
            &lt;!-- Sector 2 --&gt;
            &lt;Grid Grid.Row="2"&gt;
                &lt;Grid.ColumnDefinitions&gt;
                    &lt;ColumnDefinition Width="25"/&gt;
                    &lt;ColumnDefinition Width="55"/&gt;
                    &lt;ColumnDefinition Width="50"/&gt;
                    &lt;ColumnDefinition Width="*"/&gt;
                &lt;/Grid.ColumnDefinitions&gt;
                
                &lt;TextBlock Grid.Column="0" Text="S2" FontSize="11" Foreground="#888888"/&gt;
                &lt;TextBlock x:Name="S2Time" Grid.Column="1" Text="28.123" 
                          FontSize="12" FontWeight="Bold" Foreground="White"/&gt;
                
                &lt;TextBlock x:Name="S2Delta" Grid.Column="2" Text="+0.012" 
                          FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/&gt;
                
                &lt;Border Grid.Column="3" Background="#333333" Height="4" CornerRadius="2" 
                       Margin="5,0,0,0" VerticalAlignment="Center"&gt;
                    &lt;Rectangle x:Name="S2Bar" Fill="Orange" Width="35" 
                              HorizontalAlignment="Left" Height="4" RadiusX="2" RadiusY="2"/&gt;
                &lt;/Border&gt;
            &lt;/Grid&gt;
            
            &lt;!-- Sector 3 --&gt;
            &lt;Grid Grid.Row="3"&gt;
                &lt;Grid.ColumnDefinitions&gt;
                    &lt;ColumnDefinition Width="25"/&gt;
                    &lt;ColumnDefinition Width="55"/&gt;
                    &lt;ColumnDefinition Width="50"/&gt;
                    &lt;ColumnDefinition Width="*"/&gt;
                &lt;/Grid.ColumnDefinitions&gt;
                
                &lt;TextBlock Grid.Column="0" Text="S3" FontSize="11" Foreground="#888888"/&gt;
                &lt;TextBlock x:Name="S3Time" Grid.Column="1" Text="24.890" 
                          FontSize="12" FontWeight="Bold" Foreground="White"/&gt;
                
                &lt;TextBlock x:Name="S3Delta" Grid.Column="2" Text="-0.123" 
                          FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/&gt;
                
                &lt;Border Grid.Column="3" Background="#333333" Height="4" CornerRadius="2" 
                       Margin="5,0,0,0" VerticalAlignment="Center"&gt;
                    &lt;Rectangle x:Name="S3Bar" Fill="LimeGreen" Width="45" 
                              HorizontalAlignment="Left" Height="4" RadiusX="2" RadiusY="2"/&gt;
                &lt;/Border&gt;
            &lt;/Grid&gt;
            
            &lt;!-- Personal Best --&gt;
            &lt;StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0"&gt;
                &lt;TextBlock Text="PB: " FontSize="10" Foreground="#888888"/&gt;
                &lt;TextBlock x:Name="PersonalBestTime" Text="1:25.469" 
                          FontSize="11" FontWeight="Bold" Foreground="#AA66FF"/&gt;
                &lt;TextBlock x:Name="PersonalBestDelta" Text=" (-0.345)" 
                          FontSize="10" FontWeight="Bold" Margin="5,0,0,0"/&gt;
            &lt;/StackPanel&gt;
        &lt;/Grid&gt;
    &lt;/Border&gt;
&lt;/UserControl&gt;
