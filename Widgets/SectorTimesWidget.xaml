<UserControl x:Class="RaceLabsOverlay.Widgets.SectorTimesWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="200" Height="140">

    <Border Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1" CornerRadius="8">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="SECTORS"
                      FontSize="10" Foreground="#888888"
                      HorizontalAlignment="Center" Margin="0,0,0,5"/>

            <!-- Sector 1 -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="25"/>
                    <ColumnDefinition Width="55"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="S1" FontSize="11" Foreground="#888888"/>
                <TextBlock x:Name="S1Time" Grid.Column="1" Text="32.456"
                          FontSize="12" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="S1Delta" Grid.Column="2" Text="-0.234"
                          FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                <Border Grid.Column="3" Background="#333333" Height="4" CornerRadius="2"
                       Margin="5,0,0,0" VerticalAlignment="Center">
                    <Rectangle x:Name="S1Bar" Fill="LimeGreen" Width="40"
                              HorizontalAlignment="Left" Height="4" RadiusX="2" RadiusY="2"/>
                </Border>
            </Grid>

            <!-- Sector 2 -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="25"/>
                    <ColumnDefinition Width="55"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="S2" FontSize="11" Foreground="#888888"/>
                <TextBlock x:Name="S2Time" Grid.Column="1" Text="28.123"
                          FontSize="12" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="S2Delta" Grid.Column="2" Text="+0.012"
                          FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                <Border Grid.Column="3" Background="#333333" Height="4" CornerRadius="2"
                       Margin="5,0,0,0" VerticalAlignment="Center">
                    <Rectangle x:Name="S2Bar" Fill="Orange" Width="35"
                              HorizontalAlignment="Left" Height="4" RadiusX="2" RadiusY="2"/>
                </Border>
            </Grid>

            <!-- Sector 3 -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="25"/>
                    <ColumnDefinition Width="55"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="S3" FontSize="11" Foreground="#888888"/>
                <TextBlock x:Name="S3Time" Grid.Column="1" Text="24.890"
                          FontSize="12" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="S3Delta" Grid.Column="2" Text="-0.123"
                          FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                <Border Grid.Column="3" Background="#333333" Height="4" CornerRadius="2"
                       Margin="5,0,0,0" VerticalAlignment="Center">
                    <Rectangle x:Name="S3Bar" Fill="LimeGreen" Width="45"
                              HorizontalAlignment="Left" Height="4" RadiusX="2" RadiusY="2"/>
                </Border>
            </Grid>

            <!-- Personal Best -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                <TextBlock Text="PB: " FontSize="10" Foreground="#888888"/>
                <TextBlock x:Name="PersonalBestTime" Text="1:25.469"
                          FontSize="11" FontWeight="Bold" Foreground="#AA66FF"/>
                <TextBlock x:Name="PersonalBestDelta" Text=" (-0.345)"
                          FontSize="10" FontWeight="Bold" Margin="5,0,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
