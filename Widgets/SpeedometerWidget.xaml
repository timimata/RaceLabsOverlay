&lt;UserControl x:Class="RaceLabsOverlay.Widgets.SpeedometerWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="200" Height="120"&gt;
    
    &lt;Border Style="{StaticResource WidgetBaseStyle}"&gt;
        &lt;Grid&gt;
            &lt;Grid.RowDefinitions&gt;
                &lt;RowDefinition Height="Auto"/&gt;
                &lt;RowDefinition Height="Auto"/&gt;
            &lt;/Grid.RowDefinitions&gt;
            
            &lt;!-- Speed Value --&gt;
            &lt;TextBlock x:Name="SpeedText"
                      Grid.Row="0"
                      Text="0"
                      Style="{StaticResource SpeedometerTextStyle}"
                      HorizontalAlignment="Center"&gt;
            
            &lt;!-- Unit --&gt;
            &lt;TextBlock Grid.Row="1"
                      Text="km/h"
                      Foreground="#888888"
                      FontSize="14"
                      HorizontalAlignment="Center"
                      Margin="0,-5,0,0"&gt;
        &lt;/Grid&gt;
    &lt;/Border&gt;
&lt;/UserControl&gt;
