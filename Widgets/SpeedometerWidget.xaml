<UserControl x:Class="RaceLabsOverlay.Widgets.SpeedometerWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="200" Height="120">
    <Border Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <TextBlock x:Name="SpeedText"
                      Grid.Row="0"
                      Text="0"
                      FontSize="48"
                      FontWeight="Bold"
                      Foreground="White"
                      HorizontalAlignment="Center"
                      Margin="0,10,0,0"/>
            
            <TextBlock Grid.Row="1"
                      Text="km/h"
                      Foreground="#888888"
                      FontSize="14"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,10"/>
        </Grid>
    </Border>
</UserControl>