<UserControl x:Class="RaceLabsOverlay.Widgets.SpeedometerWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="200" Height="120">
    
    <Border Style="{StaticResource WidgetBaseStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Speed Value -->
            <TextBlock x:Name="SpeedText"
                      Grid.Row="0"
                      Text="0"
                      Style="{StaticResource SpeedometerTextStyle}"
                      HorizontalAlignment="Center">
            
            <!-- Unit -->
            <TextBlock Grid.Row="1"
                      Text="km/h"
                      Foreground="#888888"
                      FontSize="14"
                      HorizontalAlignment="Center"
                      Margin="0,-5,0,0">
        </Grid>
    </Border>
</UserControl>
