<UserControl x:Class="RaceLabsOverlay.Widgets.RPMGaugeWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="200" Height="200">
  <Border Style="{StaticResource WidgetBaseStyle}">
    <Grid>
      <Canvas>
        <Path x:Name="GaugeArc" Stroke="LimeGreen" StrokeThickness="6" />
        <TextBlock x:Name="RPMText" Text="0" FontSize="36" Foreground="White" HorizontalAlignment="Center" Canvas.Left="70" Canvas.Top="80"/>

        <!-- Shift lights -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Canvas.Top="150" Canvas.Left="20">
          <Ellipse x:Name="Light1" Width="10" Height="10" Fill="Gray" Margin="2"/>
          <Ellipse x:Name="Light2" Width="10" Height="10" Fill="Gray" Margin="2"/>
          <Ellipse x:Name="Light3" Width="10" Height="10" Fill="Gray" Margin="2"/>
          <Ellipse x:Name="Light4" Width="10" Height="10" Fill="Gray" Margin="2"/>
          <Ellipse x:Name="Light5" Width="10" Height="10" Fill="Gray" Margin="2"/>
          <Ellipse x:Name="Light6" Width="10" Height="10" Fill="Gray" Margin="2"/>
          <Ellipse x:Name="Light7" Width="10" Height="10" Fill="Gray" Margin="2"/>
          <Ellipse x:Name="Light8" Width="10" Height="10" Fill="Gray" Margin="2"/>
          <Ellipse x:Name="Light9" Width="10" Height="10" Fill="Gray" Margin="2"/>
          <Ellipse x:Name="Light10" Width="10" Height="10" Fill="Gray" Margin="2"/>
        </StackPanel>
      </Canvas>
    </Grid>
  </Border>
</UserControl>
