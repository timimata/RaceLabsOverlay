&lt;UserControl x:Class="RaceLabsOverlay.Widgets.MinimapWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="200" Height="200"&gt;
    
    &lt;Border Style="{StaticResource WidgetBaseStyle}"&gt;
        &lt;Grid&gt;
            &lt;TextBlock Text="TRACK MAP" 
                      FontSize="10" Foreground="#888888" 
                      HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,5,0,0"/&gt;
            
            &lt;Canvas x:Name="TrackCanvas" Margin="10,25,10,10"&gt;
                &lt;!-- O track path é adicionado programaticamente --&gt;
            &lt;/Canvas&gt;
            
            &lt;StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,5"&gt;
                &lt;StackPanel Orientation="Horizontal"&gt;
                    &lt;Ellipse Width="8" Height="8" Fill="Red" Margin="0,0,5,0"/&gt;
                    &lt;TextBlock Text="You" FontSize="10" Foreground="#888"/&gt;
                &lt;/StackPanel&gt;
            &lt;/StackPanel&gt;
        &lt;/Grid&gt;
    &lt;/Border&gt;
&lt;/UserControl&gt;
