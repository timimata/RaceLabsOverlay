<UserControl x:Class="RaceLabsOverlay.Widgets.MinimapWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="200" Height="200">
    
    <Border Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1" CornerRadius="8">
        <Grid>
            <TextBlock Text="MINIMAP" 
                      FontSize="10" Foreground="#888888" 
                      HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,5,0,0"/>
            
            <Canvas x:Name="TrackCanvas" Margin="10,25,10,10"/>
            
            <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,5">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="Red" Margin="0,0,5,0"/>
                    <TextBlock Text="You" FontSize="10" Foreground="#888"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
