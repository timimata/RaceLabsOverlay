&lt;UserControl x:Class="RaceLabsOverlay.Widgets.LapTimerWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="220" Height="150"&gt;
    
    &lt;Border Style="{StaticResource WidgetBaseStyle}"&gt;
        &lt;Grid&gt;
            &lt;Grid.RowDefinitions&gt;
                &lt;RowDefinition Height="Auto"/&gt;
                &lt;RowDefinition Height="Auto"/&gt;
                &lt;RowDefinition Height="Auto"/&gt;
                &lt;RowDefinition Height="Auto"/&gt;
            &lt;/Grid.RowDefinitions&gt;
            
            &lt;!-- Current Lap Time --&gt;
            &lt;StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center"&gt;
                &lt;TextBlock Text="LAP " FontSize="12" Foreground="#888888" VerticalAlignment="Bottom"/&gt;
                &lt;TextBlock x:Name="LapNumberText" Text="1" FontSize="12" Foreground="White" VerticalAlignment="Bottom" Margin="5,0,0,0"/&gt;
            &lt;/StackPanel&gt;
            
            &lt;TextBlock x:Name="CurrentLapText"
                      Grid.Row="1"
                      Text="1:23.456"
                      FontSize="36"
                      FontWeight="Bold"
                      Foreground="White"
                      HorizontalAlignment="Center"&gt;
            
            &lt;!-- Last Lap --&gt;
            &lt;StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0"&gt;
                &lt;TextBlock Text="Last: " FontSize="12" Foreground="#888888"/&gt;
                &lt;TextBlock x:Name="LastLapText" Text="1:24.123" FontSize="12" Foreground="#AAAAAA"/&gt;
            &lt;/StackPanel&gt;
            
            &lt;!-- Best Lap --&gt;
            &lt;StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,0"&gt;
                &lt;TextBlock Text="Best: " FontSize="12" Foreground="#888888"/&gt;
                &lt;TextBlock x:Name="BestLapText" Text="1:22.890" FontSize="12" Foreground="#AA66FF" FontWeight="Bold"/&gt;
            &lt;/StackPanel&gt;
        &lt;/Grid&gt;
    &lt;/Border&gt;
&lt;/UserControl&gt;
