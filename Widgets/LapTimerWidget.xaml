<UserControl x:Class="RaceLabsOverlay.Widgets.LapTimerWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="220" Height="150">
    
    <Border Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Current Lap Time -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="LAP " FontSize="12" Foreground="#888888" VerticalAlignment="Bottom"/>
                <TextBlock x:Name="LapNumberText" Text="1" FontSize="12" Foreground="White" VerticalAlignment="Bottom" Margin="5,0,0,0"/>
            </StackPanel>
            
            <TextBlock x:Name="CurrentLapText"
                      Grid.Row="1"
                      Text="1:23.456"
                      FontSize="36"
                      FontWeight="Bold"
                      Foreground="White"
                      HorizontalAlignment="Center"/>
            
            <!-- Last Lap -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                <TextBlock Text="Last: " FontSize="12" Foreground="#888888"/>
                <TextBlock x:Name="LastLapText" Text="1:24.123" FontSize="12" Foreground="#AAAAAA"/>
            </StackPanel>
            
            <!-- Best Lap -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,0">
                <TextBlock Text="Best: " FontSize="12" Foreground="#888888"/>
                <TextBlock x:Name="BestLapText" Text="1:22.890" FontSize="12" Foreground="#AA66FF" FontWeight="Bold"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
