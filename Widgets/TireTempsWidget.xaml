<UserControl x:Class="RaceLabsOverlay.Widgets.TireTempsWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="200" Height="280">
  <Border Style="{StaticResource WidgetBaseStyle}">
    <Grid Margin="8">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Left Front -->
      <StackPanel Grid.Row="0" Grid.Column="0" Margin="4">
        <TextBlock Text="LF" Foreground="#888" FontSize="10"/>
        <Border x:Name="LFInner"  Height="12" Background="#222" Margin="0,2"/>
        <Border x:Name="LFCenter" Height="12" Background="#222" Margin="0,2"/>
        <Border x:Name="LFOuter"  Height="12" Background="#222" Margin="0,2"/>
        <TextBlock x:Name="LFAvg" Text="--°" Foreground="White" HorizontalAlignment="Center"/>
      </StackPanel>

      <!-- Right Front -->
      <StackPanel Grid.Row="0" Grid.Column="1" Margin="4">
        <TextBlock Text="RF" Foreground="#888" FontSize="10"/>
        <Border x:Name="RFInner"  Height="12" Background="#222" Margin="0,2"/>
        <Border x:Name="RFCenter" Height="12" Background="#222" Margin="0,2"/>
        <Border x:Name="RFOuter"  Height="12" Background="#222" Margin="0,2"/>
        <TextBlock x:Name="RFAvg" Text="--°" Foreground="White" HorizontalAlignment="Center"/>
      </StackPanel>

      <!-- Left Rear -->
      <StackPanel Grid.Row="1" Grid.Column="0" Margin="4">
        <TextBlock Text="LR" Foreground="#888" FontSize="10"/>
        <Border x:Name="LRInner"  Height="12" Background="#222" Margin="0,2"/>
        <Border x:Name="LRCenter" Height="12" Background="#222" Margin="0,2"/>
        <Border x:Name="LROuter"  Height="12" Background="#222" Margin="0,2"/>
        <TextBlock x:Name="LRAvg" Text="--°" Foreground="White" HorizontalAlignment="Center"/>
      </StackPanel>

      <!-- Right Rear -->
      <StackPanel Grid.Row="1" Grid.Column="1" Margin="4">
        <TextBlock Text="RR" Foreground="#888" FontSize="10"/>
        <Border x:Name="RRInner"  Height="12" Background="#222" Margin="0,2"/>
        <Border x:Name="RRCenter" Height="12" Background="#222" Margin="0,2"/>
        <Border x:Name="RROuter"  Height="12" Background="#222" Margin="0,2"/>
        <TextBlock x:Name="RRAvg" Text="--°" Foreground="White" HorizontalAlignment="Center"/>
      </StackPanel>
    </Grid>
  </Border>
</UserControl>
