<UserControl x:Class="RaceLabsOverlay.Widgets.TireTempsWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="200" Height="150">
    
    <Border Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1" CornerRadius="8">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0" Text="TIRE TEMPS" 
                      FontSize="10" Foreground="#888888" 
                      HorizontalAlignment="Center" Margin="0,0,0,5"/>
            
            <!-- Front Tires -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border x:Name="LFTire" Grid.Column="0" Background="#333333" CornerRadius="4" Margin="2" Padding="5">
                    <TextBlock x:Name="LFTemp" Text="LF: 85°" Foreground="White" HorizontalAlignment="Center" FontSize="12"/>
                </Border>
                
                <Border x:Name="RFTire" Grid.Column="1" Background="#333333" CornerRadius="4" Margin="2" Padding="5">
                    <TextBlock x:Name="RFTemp" Text="RF: 85°" Foreground="White" HorizontalAlignment="Center" FontSize="12"/>
                </Border>
            </Grid>
            
            <!-- Rear Tires -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border x:Name="LRTire" Grid.Column="0" Background="#333333" CornerRadius="4" Margin="2" Padding="5">
                    <TextBlock x:Name="LRTemp" Text="LR: 85°" Foreground="White" HorizontalAlignment="Center" FontSize="12"/>
                </Border>
                
                <Border x:Name="RRTire" Grid.Column="1" Background="#333333" CornerRadius="4" Margin="2" Padding="5">
                    <TextBlock x:Name="RRTemp" Text="RR: 85°" Foreground="White" HorizontalAlignment="Center" FontSize="12"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
