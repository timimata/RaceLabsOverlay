<UserControl x:Class="RaceLabsOverlay.Widgets.DeltaBarWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="300" Height="60">
    <Border Style="{StaticResource WidgetBaseStyle}">
        <Grid x:Name="BarContainer" Height="40">
            <Rectangle Fill="#333333" />

            <Rectangle x:Name="NegativeBar" HorizontalAlignment="Left" Fill="LimeGreen" Width="0" Height="8" VerticalAlignment="Center" Margin="0,0,0,0"/>
            <Rectangle x:Name="PositiveBar" HorizontalAlignment="Right" Fill="Red" Width="0" Height="8" VerticalAlignment="Center" Margin="0,0,0,0"/>

            <Rectangle x:Name="CenterMarker" Width="2" Height="20" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>

            <TextBlock x:Name="DeltaText" Text="0.00" FontSize="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,22,0,0"/>
        </Grid>
    </Border>
</UserControl>
