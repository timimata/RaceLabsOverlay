<UserControl x:Class="RaceLabsOverlay.Widgets.DeltaBarWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="300" Height="60">
    
    <Border Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1" CornerRadius="8">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0" Text="DELTA" 
                      FontSize="10" Foreground="#888888" 
                      HorizontalAlignment="Center"/>
            
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Barra negativa (à frente) -->
                <Border x:Name="NegativeBarContainer" Grid.Column="0" 
                        Background="#333333" Height="8" CornerRadius="4"
                        HorizontalAlignment="Right" Width="100">
                    <Rectangle x:Name="NegativeBar" Fill="LimeGreen" 
                              HorizontalAlignment="Right" Width="0"
                              RadiusX="4" RadiusY="4"/>
                </Border>
                
                <!-- Centro -->
                <TextBlock x:Name="DeltaText" Grid.Column="1" 
                          Text="—.——" FontSize="14" FontWeight="Bold"
                          Foreground="Gray" Margin="10,0"/>
                
                <!-- Barra positiva (atrás) -->
                <Border x:Name="PositiveBarContainer" Grid.Column="2" 
                        Background="#333333" Height="8" CornerRadius="4"
                        HorizontalAlignment="Left" Width="100">
                    <Rectangle x:Name="PositiveBar" Fill="Red" 
                              HorizontalAlignment="Left" Width="0"
                              RadiusX="4" RadiusY="4"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
