<UserControl x:Class="RaceLabsOverlay.Widgets.FuelWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="200" Height="120">
    
    <Border Style="{StaticResource WidgetBaseStyle}">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Fuel Level -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="FuelText" Text="45.2" 
                          FontSize="28" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text=" L" FontSize="14" Foreground="#888888" 
                          VerticalAlignment="Bottom" Margin="2,0,0,5"/>
            </StackPanel>
            
            <!-- Percentage Bar -->
            <Border Grid.Row="1" Background="#333333" Height="8" CornerRadius="4" Margin="0,5">
                <Rectangle x:Name="FuelBar" 
                          Fill="#0088FF" 
                          HorizontalAlignment="Left"
                          Width="0"
                          RadiusX="4"
                          RadiusY="4"/>
            </Border>
            
            <!-- Fuel Info -->
            <Grid Grid.Row="2" Margin="0,5,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Laps" FontSize="10" Foreground="#888888"/>
                    <TextBlock x:Name="LapsRemainingText" Text="12" FontSize="16" Foreground="White"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Text="L/lap" FontSize="10" Foreground="#888888"/>
                    <TextBlock x:Name="ConsumptionText" Text="3.8" FontSize="16" Foreground="White"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
