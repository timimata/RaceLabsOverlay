<UserControl x:Class="RaceLabsOverlay.Widgets.TelemetryGraphWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Width="500" Height="300">
    
    <Border Style="{StaticResource WidgetBaseStyle}">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Header com valores atuais -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                <TextBlock Text="TELEMETRY" FontSize="10" Foreground="#888888" Margin="0,0,10,0"/>
                <TextBlock x:Name="CurrentSpeedText" Text="0 km/h" FontSize="11" Foreground="LimeGreen" FontWeight="Bold"/>
                <TextBlock Text=" • " Foreground="#555"/>
                <TextBlock x:Name="CurrentRpmText" Text="0 RPM" FontSize="11" Foreground="Orange" FontWeight="Bold"/>
                <TextBlock Text=" • " Foreground="#555"/>
                <TextBlock x:Name="CurrentGearText" Text="Gear N" FontSize="11" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
            
            <!-- Speed Chart -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="25"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="SPD" FontSize="8" Foreground="#888888" 
                          VerticalAlignment="Center" HorizontalAlignment="Center"
                          RenderTransform="{StaticResource Rotate90}"/>
                
                <lvc:CartesianChart x:Name="SpeedChart" Grid.Column="1"
                                   Height="60"
                                   Background="Transparent"
                                   DrawMarginFrame="False"
                                   TooltipPosition="Hidden"/>
            </Grid>
            
            <!-- RPM Chart -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="25"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="RPM" FontSize="8" Foreground="#888888" 
                          VerticalAlignment="Center" HorizontalAlignment="Center"
                          RenderTransform="{StaticResource Rotate90}"/>
                
                <lvc:CartesianChart x:Name="RpmChart" Grid.Column="1"
                                   Height="60"
                                   Background="Transparent"
                                   DrawMarginFrame="False"
                                   TooltipPosition="Hidden"/>
            </Grid>
            
            <!-- Inputs Chart -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="25"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="IN" FontSize="8" Foreground="#888888" 
                          VerticalAlignment="Center" HorizontalAlignment="Center"
                          RenderTransform="{StaticResource Rotate90}"/>
                
                <lvc:CartesianChart x:Name="InputsChart" Grid.Column="1"
                                   Height="60"
                                   Background="Transparent"
                                   DrawMarginFrame="False"
                                   TooltipPosition="Hidden"/>
            </Grid>
        </Grid>
    </Border>
    
    <UserControl.Resources>
        <RotateTransform x:Key="Rotate90" Angle="-90"/>
    </UserControl.Resources>
</UserControl>
