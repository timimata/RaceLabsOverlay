<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Colors -->
  <Color x:Key="BackgroundDark">#0A0A0A</Color>
  <Color x:Key="BackgroundPanel">#1A1A1A</Color>
  <Color x:Key="TextPrimary">#FFFFFFFF</Color>
  <Color x:Key="TextSecondary">#888888</Color>
  <Color x:Key="AccentGreen">#00FF00</Color>
  <Color x:Key="AccentBlue">#0088FF</Color>

  <!-- Brushes -->
  <SolidColorBrush x:Key="BackgroundPanelBrush" Color="{StaticResource BackgroundPanel}"/>
  <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
  <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>

  <!-- Widget Base Style -->
  <Style x:Key="WidgetBaseStyle" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource BackgroundPanelBrush}"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="BorderBrush" Value="#333333"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="10"/>
    <Setter Property="Opacity" Value="0.95"/>
  </Style>

  <Style x:Key="SpeedometerTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="Segoe UI, Arial"/>
    <Setter Property="FontSize" Value="72"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
  </Style>

  <Style x:Key="DeltaTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="Consolas, Monospace"/>
    <Setter Property="FontSize" Value="32"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="HorizontalAlignment" Value="Center"/>
  </Style>

  <Style x:Key="TextSecondaryStyle" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    <Setter Property="FontSize" Value="14"/>
  </Style>

  <Style x:Key="WidgetTransparentStyle" TargetType="Border" BasedOn="{StaticResource WidgetBaseStyle}">
    <Setter Property="Background" Value="#001A1A1A"/>
    <Setter Property="BorderBrush" Value="#00333333"/>
  </Style>

  <Style x:Key="GlowTextStyle" TargetType="TextBlock">
    <Setter Property="Effect">
      <Setter.Value>
        <DropShadowEffect ShadowDepth="0" BlurRadius="8" Color="#00FF00" Opacity="0.8"/>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>
