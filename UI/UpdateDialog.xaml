<Window x:Class="RaceLabsOverlay.UI.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Available" 
        Height="400" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1A1A1A">
    
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#444444"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
            <TextBlock Text="🎉 " FontSize="24"/>
            <TextBlock Text="Update Available!" 
                      FontSize="24" 
                      FontWeight="Bold" 
                      Foreground="LimeGreen"/>
        </StackPanel>
        
        <!-- Version Info -->
        <StackPanel Grid.Row="1" Margin="0,15,0,0" HorizontalAlignment="Center">
            <TextBlock x:Name="CurrentVersionText" 
                      Text="Current: v0.1.0"
                      FontSize="12"
                      Foreground="#888888"/>
            
            <TextBlock x:Name="NewVersionText" 
                      Text="New: v0.2.0"
                      FontSize="14"
                      Foreground="White"
                      FontWeight="Bold"
                      Margin="0,5,0,0"/>
        </StackPanel>
        
        <!-- Release Notes -->
        <Border Grid.Row="2" 
                Background="#0A0A0A" 
                BorderBrush="#333333"
                BorderThickness="1"
                CornerRadius="5"
                Margin="0,15,0,0">
            
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         Margin="10">
                <TextBlock x:Name="ReleaseNotesText"
                          Text="Release notes..."
                          Foreground="#CCCCCC"
                          TextWrapping="Wrap"
                          FontSize="12"/>
            </ScrollViewer>
        </Border>
        
        <!-- Progress Bar (hidden by default) -->
        <Grid Grid.Row="3" x:Name="ProgressGrid" Visibility="Collapsed" Margin="0,10,0,0">
            <ProgressBar x:Name="DownloadProgress" 
                        Height="20"
                        Background="#333333"
                        Foreground="LimeGreen"
                        BorderThickness="0"/>
            
            <TextBlock x:Name="ProgressText"
                      Text="Downloading... 0%"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Foreground="White"
                      FontSize="11"/>
        </Grid>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="4" 
                     Orientation="Horizontal" 
                     HorizontalAlignment="Center"
                     Margin="0,15,0,0">
            
            <Button x:Name="UpdateButton"
                   Content="Update Now"
                   Click="UpdateButton_Click"
                   Background="#228822"
                   Margin="0,0,10,0"/>
            
            <Button x:Name="LaterButton"
                   Content="Remind Me Later"
                   Click="LaterButton_Click"
                   Margin="0,0,10,0"/>
            
            <Button x:Name="SkipButton"
                   Content="Skip This Version"
                   Click="SkipButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
