&lt;Window x:Class="RaceLabsOverlay.UI.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Available" 
        Height="400" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1A1A1A"&gt;
    
    &lt;Window.Resources&gt;
        &lt;Style TargetType="Button"&gt;
            &lt;Setter Property="Background" Value="#333333"/&gt;
            &lt;Setter Property="Foreground" Value="White"/&gt;
            &lt;Setter Property="BorderBrush" Value="#555555"/&gt;
            &lt;Setter Property="Padding" Value="15,8"/&gt;
            &lt;Setter Property="FontSize" Value="14"/&gt;
            &lt;Style.Triggers&gt;
                &lt;Trigger Property="IsMouseOver" Value="True"&gt;
                    &lt;Setter Property="Background" Value="#444444"/&gt;
                &lt;/Trigger&gt;
            &lt;/Style.Triggers&gt;
        &lt;/Style&gt;
    &lt;/Window.Resources&gt;
    
    &lt;Grid Margin="20"&gt;
        &lt;Grid.RowDefinitions&gt;
            &lt;RowDefinition Height="Auto"/&gt;
            &lt;RowDefinition Height="Auto"/&gt;
            &lt;RowDefinition Height="*"/&gt;
            &lt;RowDefinition Height="Auto"/&gt;
            &lt;RowDefinition Height="Auto"/&gt;
        &lt;/Grid.RowDefinitions&gt;
        
        &lt;!-- Header --&gt;
        &lt;StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center"&gt;
            &lt;TextBlock Text="🎉 " FontSize="24"/&gt;
            &lt;TextBlock Text="Update Available!" 
                      FontSize="24" 
                      FontWeight="Bold" 
                      Foreground="LimeGreen"/&gt;
        &lt;/StackPanel&gt;
        
        &lt;!-- Version Info --&gt;
        &lt;StackPanel Grid.Row="1" Margin="0,15,0,0" HorizontalAlignment="Center"&gt;
            &lt;TextBlock x:Name="CurrentVersionText" 
                      Text="Current: v0.1.0"
                      FontSize="12"
                      Foreground="#888888"/&gt;
            
            &lt;TextBlock x:Name="NewVersionText" 
                      Text="New: v0.2.0"
                      FontSize="14"
                      Foreground="White"
                      FontWeight="Bold"
                      Margin="0,5,0,0"/&gt;
        &lt;/StackPanel&gt;
        
        &lt;!-- Release Notes --&gt;
        &lt;Border Grid.Row="2" 
                Background="#0A0A0A" 
                BorderBrush="#333333"
                BorderThickness="1"
                CornerRadius="5"
                Margin="0,15,0,0"&gt;
            
            &lt;ScrollViewer VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         Margin="10"&gt;
                &lt;TextBlock x:Name="ReleaseNotesText"
                          Text="Release notes..."
                          Foreground="#CCCCCC"
                          TextWrapping="Wrap"
                          FontSize="12"/&gt;
            &lt;/ScrollViewer&gt;
        &lt;/Border&gt;
        
        &lt;!-- Progress Bar (hidden by default) --&gt;
        &lt;Grid Grid.Row="3" x:Name="ProgressGrid" Visibility="Collapsed" Margin="0,10,0,0"&gt;
            &lt;ProgressBar x:Name="DownloadProgress" 
                        Height="20"
                        Background="#333333"
                        Foreground="LimeGreen"
                        BorderThickness="0"/&gt;
            
            &lt;TextBlock x:Name="ProgressText"
                      Text="Downloading... 0%"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Foreground="White"
                      FontSize="11"/&gt;
        &lt;/Grid&gt;
        
        &lt;!-- Buttons --&gt;
        &lt;StackPanel Grid.Row="4" 
                     Orientation="Horizontal" 
                     HorizontalAlignment="Center"
                     Margin="0,15,0,0"&gt;
            
            &lt;Button x:Name="UpdateButton"
                   Content="Update Now"
                   Click="UpdateButton_Click"
                   Background="#228822"
                   Margin="0,0,10,0"/&gt;
            
            &lt;Button x:Name="LaterButton"
                   Content="Remind Me Later"
                   Click="LaterButton_Click"
                   Margin="0,0,10,0"/&gt;
            
            &lt;Button x:Name="SkipButton"
                   Content="Skip This Version"
                   Click="SkipButton_Click"/&gt;
        &lt;/StackPanel&gt;
    &lt;/Grid&gt;
&lt;/Window&gt;
