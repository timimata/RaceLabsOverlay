&lt;Window x:Class="RaceLabsOverlay.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" 
        Height="500" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1A1A1A"&gt;
    
    &lt;Window.Resources&gt;
        &lt;Style TargetType="TabItem"&gt;
            &lt;Setter Property="Foreground" Value="#CCCCCC"/&gt;
            &lt;Setter Property="Padding" Value="15,10"/&gt;
            &lt;Setter Property="Template"&gt;
                &lt;Setter.Value&gt;
                    &lt;ControlTemplate TargetType="TabItem"&gt;
                        &lt;Border Name="Border" 
                                Background="#222222" 
                                BorderBrush="#333333"
                                BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}"&gt;
                            &lt;ContentPresenter Content="{TemplateBinding Header}"
                                            TextBlock.Foreground="{TemplateBinding Foreground}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/&gt;
                        &lt;/Border&gt;
                        &lt;ControlTemplate.Triggers&gt;
                            &lt;Trigger Property="IsSelected" Value="True"&gt;
                                &lt;Setter TargetName="Border" Property="BorderBrush" Value="LimeGreen"/&gt;
                                &lt;Setter TargetName="Border" Property="Background" Value="#2A2A2A"/&gt;
                                &lt;Setter Property="Foreground" Value="White"/&gt;
                            &lt;/Trigger&gt;
                            &lt;Trigger Property="IsMouseOver" Value="True"&gt;
                                &lt;Setter TargetName="Border" Property="Background" Value="#333333"/&gt;
                            &lt;/Trigger&gt;
                        &lt;/ControlTemplate.Triggers&gt;
                    &lt;/ControlTemplate&gt;
                &lt;/Setter.Value&gt;
            &lt;/Setter&gt;
        &lt;/Style&gt;
    &lt;/Window.Resources&gt;
    
    &lt;Grid&gt;
        &lt;Grid.RowDefinitions&gt;
            &lt;RowDefinition Height="*"/&gt;
            &lt;RowDefinition Height="Auto"/&gt;
        &lt;/Grid.RowDefinitions&gt;
        
        &lt;TabControl Grid.Row="0" Background="Transparent" BorderThickness="0"&gt;
            
            &lt;!-- General --&gt;
            &lt;TabItem Header="General"&gt;
                &lt;ScrollViewer VerticalScrollBarVisibility="Auto" Margin="20"&gt;
                    &lt;StackPanel&gt;
                        &lt;TextBlock Text="Startup" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/&gt;
                        
                        &lt;CheckBox x:Name="StartWithWindowsCheck" 
                                 Content="Start with Windows"
                                 Foreground="#CCCCCC"
                                 Margin="0,5"&gt;
                        &lt;/CheckBox&gt;
                        
                        &lt;CheckBox x:Name="CheckUpdatesCheck" 
                                 Content="Check for updates on startup"
                                 Foreground="#CCCCCC"
                                 Margin="0,5"&gt;
                        &lt;/CheckBox&gt;
                        
                        &lt;CheckBox x:Name="MinimizeToTrayCheck" 
                                 Content="Minimize to system tray"
                                 Foreground="#CCCCCC"
                                 Margin="0,5"&gt;
                        &lt;/CheckBox&gt;
                        
                        &lt;TextBlock Text="Updates" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,20,0,10"/&gt;
                        
                        &lt;StackPanel Orientation="Horizontal" Margin="0,5"&gt;
                            &lt;TextBlock Text="Update Channel:" Foreground="#CCCCCC" Width="120" VerticalAlignment="Center"/&gt;
                            &lt;ComboBox x:Name="UpdateChannelCombo" Width="150" Background="#333333" Foreground="White"&gt;
                                &lt;ComboBoxItem Content="Stable"/&gt;
                                &lt;ComboBoxItem Content="Beta"/&gt;
                                &lt;ComboBoxItem Content="Development"/&gt;
                            &lt;/ComboBox&gt;
                        &lt;/StackPanel&gt;
                    &lt;/StackPanel&gt;
                &lt;/ScrollViewer&gt;
            &lt;/TabItem&gt;
            
            &lt;!-- Overlay --&gt;
            &lt;TabItem Header="Overlay"&gt;
                &lt;ScrollViewer VerticalScrollBarVisibility="Auto" Margin="20"&gt;
                    &lt;StackPanel&gt;
                        &lt;TextBlock Text="Appearance" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/&gt;
                        
                        &lt;StackPanel Orientation="Horizontal" Margin="0,5"&gt;
                            &lt;TextBlock Text="Opacity:" Foreground="#CCCCCC" Width="120" VerticalAlignment="Center"/&gt;
                            &lt;Slider x:Name="OpacitySlider" Width="200" Minimum="0.3" Maximum="1.0" Value="0.95" 
                                   TickFrequency="0.05"/&gt;
                            &lt;TextBlock x:Name="OpacityValue" Text="95%" Foreground="White" Margin="10,0,0,0"/&gt;
                        &lt;/StackPanel&gt;
                        
                        &lt;CheckBox x:Name="ClickThroughCheck" 
                                 Content="Click-through by default"
                                 Foreground="#CCCCCC"
                                 Margin="0,10"&gt;
                        &lt;/CheckBox&gt;
                        
                        &lt;TextBlock Text="Ghost Racing" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,20,0,10"/&gt;
                        
                        &lt;CheckBox x:Name="EnableGhostCheck" 
                                 Content="Enable ghost recording"
                                 Foreground="#CCCCCC"
                                 Margin="0,5"&gt;
                        &lt;/CheckBox&gt;
                        
                        &lt;CheckBox x:Name="AutoSaveGhostCheck" 
                                 Content="Auto-save ghost on best lap"
                                 Foreground="#CCCCCC"
                                 Margin="0,5"&gt;
                        &lt;/CheckBox&gt;
                    &lt;/StackPanel&gt;
                &lt;/ScrollViewer&gt;
            &lt;/TabItem&gt;
            
            &lt;!-- Hotkeys --&gt;
            &lt;TabItem Header="Hotkeys"&gt;
                &lt;ScrollViewer VerticalScrollBarVisibility="Auto" Margin="20"&gt;
                    &lt;StackPanel&gt;
                        &lt;TextBlock Text="Keyboard Shortcuts" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/&gt;
                        
                        &lt;Grid&gt;
                            &lt;Grid.ColumnDefinitions&gt;
                                &lt;ColumnDefinition Width="*"/&gt;
                                &lt;ColumnDefinition Width="150"/&gt;
                            &lt;/Grid.ColumnDefinitions&gt;
                            
                            &lt;TextBlock Grid.Column="0" Text="Toggle Edit Mode:" Foreground="#CCCCCC"/&gt;
                            &lt;TextBox Grid.Column="1" x:Name="EditModeHotkey" Text="Ctrl+Shift+O" Background="#333333" Foreground="White"/&gt;
                        &lt;/Grid&gt;
                        
                        &lt;Grid Margin="0,10"&gt;
                            &lt;Grid.ColumnDefinitions&gt;
                                &lt;ColumnDefinition Width="*"/&gt;
                                &lt;ColumnDefinition Width="150"/&gt;
                            &lt;/Grid.ColumnDefinitions&gt;
                            
                            &lt;TextBlock Grid.Column="0" Text="Toggle Click-Through:" Foreground="#CCCCCC"/&gt;
                            &lt;TextBox Grid.Column="1" x:Name="ClickThroughHotkey" Text="Ctrl+Shift+H" Background="#333333" Foreground="White"/&gt;
                        &lt;/Grid&gt;
                        
                        &lt;Grid&gt;
                            &lt;Grid.ColumnDefinitions&gt;
                                &lt;ColumnDefinition Width="*"/&gt;
                                &lt;ColumnDefinition Width="150"/&gt;
                            &lt;/Grid.ColumnDefinitions&gt;
                            
                            &lt;TextBlock Grid.Column="0" Text="Record Ghost:" Foreground="#CCCCCC"/&gt;
                            &lt;TextBox Grid.Column="1" x:Name="RecordGhostHotkey" Text="Ctrl+Shift+R" Background="#333333" Foreground="White"/&gt;
                        &lt;/Grid&gt;
                    &lt;/StackPanel&gt;
                &lt;/ScrollViewer&gt;
            &lt;/TabItem&gt;
            
            &lt;!-- About --&gt;
            &lt;TabItem Header="About"&gt;
                &lt;StackPanel Margin="20" HorizontalAlignment="Center"&gt;
                    &lt;TextBlock Text="🏎️" FontSize="48" HorizontalAlignment="Center"/&gt;
                    
                    &lt;TextBlock Text="RaceLabs Overlay" FontSize="24" FontWeight="Bold" Foreground="White" 
                              HorizontalAlignment="Center" Margin="0,20,0,5"/&gt;
                    
                    &lt;TextBlock x:Name="VersionText" Text="Version 0.1.0" FontSize="14" Foreground="#888888" 
                              HorizontalAlignment="Center"/&gt;
                    
                    &lt;TextBlock Text="Professional iRacing Telemetry Overlay" FontSize="12" Foreground="#666666" 
                              HorizontalAlignment="Center" Margin="0,20,0,0"/&gt;
                    
                    &lt;TextBlock Text="© 2026 Tiago" FontSize="11" Foreground="#555555" 
                              HorizontalAlignment="Center" Margin="0,10,0,0"/&gt;
                    
                    &lt;Button x:Name="CheckUpdateButton" Content="Check for Updates" Width="150" Margin="0,30,0,0"
                           Background="#333333" Foreground="White" Click="CheckUpdateButton_Click"/&gt;
                &lt;/StackPanel&gt;
            &lt;/TabItem&gt;
        &lt;/TabControl&gt;
        
        &lt;!-- Buttons --&gt;
        &lt;StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20"&gt;
            &lt;Button Content="Save" Width="80" Height="30" Margin="0,0,10,0"
                   Background="#228822" Foreground="White" Click="SaveButton_Click"/&gt;
            
            &lt;Button Content="Cancel" Width="80" Height="30"
                   Background="#333333" Foreground="White" Click="CancelButton_Click"/&gt;
        &lt;/StackPanel&gt;
    &lt;/Grid&gt;
&lt;/Window&gt;
