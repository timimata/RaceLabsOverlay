&lt;Window x:Class="RaceLabsOverlay.UI.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RaceLabs Overlay"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Width="1920"
        Height="1080"
        WindowStartupLocation="Manual"
        Left="0"
        Top="0"&gt;
    
    &lt;Grid&gt;
        &lt;!-- Canvas para os widgets --&gt;
        &lt;Canvas x:Name="WidgetsCanvas" 
                Background="Transparent"&gt;
        &lt;/Canvas&gt;
        
        &lt;!-- Notificação flutuante --&gt;
        &lt;Border x:Name="NotificationBorder"
                Background="#CC000000"
                BorderBrush="#444444"
                BorderThickness="1"
                CornerRadius="8"
                Padding="15,10"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,20,0,0"
                Visibility="Collapsed"&gt;
            &lt;TextBlock x:Name="NotificationText"
                      Text="Welcome"
                      Foreground="White"
                      FontSize="14"&gt;
        &lt;/Border&gt;
    &lt;/Grid&gt;
&lt;/Window&gt;
