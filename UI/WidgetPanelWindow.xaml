<Window x:Class="RaceLabsOverlay.UI.WidgetPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RaceLabs - Widgets"
        Width="300"
        Height="420"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A1A">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Toggle Widgets"
                   Foreground="#00FF00"
                   FontSize="16"
                   FontWeight="Bold"
                   Margin="0,0,0,12"/>

        <!-- Widget list -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="WidgetList" />
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
            <Button x:Name="ResetButton" Content="Reset Layout" Click="ResetButton_Click"
                    Width="120" Height="30" Margin="0,0,8,0"
                    Background="#333333" Foreground="White" BorderBrush="#555555"
                    FontSize="12" Cursor="Hand"/>
            <Button x:Name="EditModeButton" Content="Edit Mode" Click="EditModeButton_Click"
                    Width="120" Height="30"
                    Background="#333333" Foreground="White" BorderBrush="#555555"
                    FontSize="12" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
